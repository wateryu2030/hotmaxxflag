# 货盘价格对比 - 竞品价格检索配置
# 复制为 .env 并填入真实 key（.env 已加入 .gitignore，不会提交）

# OneBound 万邦（推荐，关键词搜索返回真实价格）
# 申请：https://console.open.onebound.cn/console/ 注册开通，约 0.02-0.09 元/次
ONEBOUND_KEY=
ONEBOUND_SECRET=
# 对标平台：jd=京东（默认）, taobao=淘宝
ONEBOUND_PLATFORM=jd

# 蚂蚁星球（免费，京东+拼多多+蘑菇街 三合一，OneBound 不可用时的替代）
# 申请：https://www.haojingke.com/open-api/pdd 注册后申请 apikey
# 需在开发者中心完成：京东联盟设置、多多进宝设置
PDD_HOJINGKE_APIKEY=

# 聚合数据 商品比价（备选，曾维护中，申请前请确认已恢复）
# 申请：https://www.juhe.cn/docs/api/id/137
JUHE_PRICE_KEY=

# 百度 API 商城（商品条码/商品搜索类 API）
# 申请：https://apis.baidu.com/ 搜索「商品条码」或「商品搜索」购买
BAIDU_APISTORE_KEY=

# 百度优选开放平台（商品检索、SPU 全维度对比）
# 控制台：百度优选开放平台 → 工具权限，复制密钥
# BAIDU_YOUXUAN_TOKEN=

# 百度智能云 AK/SK（用于需 AK/SK 鉴权的 API）
# 获取：https://console.bce.baidu.com/iam/#/iam/accesslist
# BAIDU_AK=
# BAIDU_SK=

# OpenClaw 网关（货盘比价走网关 /tools/invoke 时必填）
# 看板后端请求网关需带 Bearer token，否则返回 Unauthorized、页面出现「请求失败: Failed to fetch」
# 获取 token：~/.openclaw/openclaw.json 中 gateway.auth.token，或控制台带 token 的 Dashboard URL 里的 #token=xxx
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=粘贴 gateway.auth.token 的值

# 百度 Skill 专用网关（优先用百度电商比价 Skill，因 clawhub 上已无 baidu-preferred）
# 配置为「已安装百度 Skill 且可用」的 OpenClaw 网关地址（如手机端/其他机器上的网关，或曾安装过该 skill 的网关）
# 配置后看板与 runner 会优先请求该 URL 的 /tools/invoke，不再依赖本机 clawhub install。详见 docs/百度Skill优先-无clawhub方案.md
# OPENCLAW_BAIDU_SKILL_GATEWAY_URL=https://你的网关地址或 http://手机内网IP:18789
# OPENCLAW_BAIDU_SKILL_GATEWAY_TOKEN=该网关的 Bearer token（不填则用 OPENCLAW_GATEWAY_TOKEN）

# 真实 API 时限制比价商品数以控制成本（如 50），其余标为独家款
# PRICE_COMPARE_FETCH_LIMIT=50

# OpenClaw / 大模型 API（OpenAI 兼容，供 OpenClaw 直接调用大模型）
# OPENAI_API_KEY=sk-xxx

# ---------- 登录（飞书扫码授权，保护敏感数据）----------
# 在飞书开放平台创建自建应用后填写，未配置则不启用登录（所有人可访问）
# 创建应用：https://open.feishu.cn/app  → 创建企业自建应用 → 凭证与基础信息 获取 App ID / App Secret
# 安全设置：添加「重定向 URL」为 https://你的看板域名/api/auth/feishu_callback（与访问看板的域名一致）
# 权限：开通  contact:user.base:readonly（获取用户基础信息）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# 飞书回调与登录页跳转使用此地址（代理/Cloudflare 时必须设，与飞书控制台重定向 URL 一致）
# HTMA_PUBLIC_URL=https://htma.greatagain.com.cn
# 可选：仅允许以下 open_id 登录（逗号分隔）。不填或留空则允许本企业内所有飞书用户登录（振鸿科技群等全员可见）
# HTMA_ALLOWED_FEISHU_OPEN_IDS=ou_xxx,ou_yyy
# 若希望全员可访问，请勿设置此项，或显式留空： HTMA_ALLOWED_FEISHU_OPEN_IDS=
# 超级管理员 open_id（企业外用户审批人，默认余为军）。该账号飞书登录后拥有全部模块权限（数据导入、人力成本、人力分析、毛利等），便于调试
# HTMA_SUPER_ADMIN_OPEN_ID=8db735f2
# 可选：额外拥有全部模块权限的 open_id 列表（逗号分隔），与超级管理员等效
# HTMA_ADMIN_FEISHU_OPEN_IDS=ou_xxx,ou_yyy
# 会话加密密钥（生产环境必改，否则会话可被伪造）
# FLASK_SECRET_KEY=随机长字符串
# HTTPS 部署时建议开启
# SESSION_COOKIE_SECURE=1

# ---------- 飞书机器人（群内 @ 对话 / 私聊）----------
# 详见 docs/飞书群机器人对话配置.md。事件订阅请求 URL：https://你的域名/api/feishu/bot/event
# FEISHU_VERIFICATION_TOKEN=与事件订阅「Verification Token」一致（强烈建议）
# FEISHU_ENCRYPT_KEY=若开启事件加密则必填（需 pip install pycryptodome）
# FEISHU_BOT_REPLY_MODE=mention
# FEISHU_BOT_REPLY_PREFIX=【好特卖】
# FEISHU_BOT_OPEN_ID=
# 机器人只读查库白名单（open_id 逗号分隔；不填则拒绝库查询）。内网测试可填 *（生产勿用）
# FEISHU_BOT_DB_ALLOWED_OPEN_IDS=
# FEISHU_BOT_MYSQL_USER=
# FEISHU_BOT_MYSQL_PASSWORD=
# FEISHU_BOT_DB_REQUIRE_ALLOWLIST=1

# ---------- 多通道通知（飞书 + 企业微信 + 钉钉，一次设置多项目可复用）----------
# 飞书：群机器人 Webhook（报告/比价等会推送到该群）
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# FEISHU_AT_USER_ID=ou_xxxxxxxx
# FEISHU_AT_USER_NAME=接收人姓名

# 企业微信：群机器人 Webhook（群设置 → 添加群机器人 → 复制 webhook）
# WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# 钉钉：自定义机器人 Webhook（群设置 → 智能群助手 → 添加机器人 → 自定义 → 复制 URL；加签时填 SECRET）
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx
# DINGTALK_SECRET=SECxxxxxxxx

# ---------- 人力成本（实际支付与统计缺口）----------
# 实际支付金额（元，如开票/总成本），用于与全口径统计对比、展示「统计缺口」及可能原因说明（如实际支付 53 万 = 530000）
# TARGET_LABOR_COST_YUAN=530000

# ---------- MySQL（看板与脚本共用，本地开发常用默认）----------
# 不配置时，代码内默认 host=127.0.0.1 port=3306 user=root password=62102218 database=htma_dashboard
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=你的密码
# MYSQL_DATABASE=htma_dashboard
